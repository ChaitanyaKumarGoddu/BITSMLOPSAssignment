{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Heart Disease API — Monitoring",
  "uid": "heart-api-dash",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Total Predictions",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(heart_predictions_total)", "legendFormat": "total" }
      ]
    },
    {
      "type": "piechart",
      "title": "Prediction Outcomes",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum by (outcome) (heart_predictions_total)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (handler)", "legendFormat": "{{handler}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95 (s)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))", "legendFormat": "p95 {{handler}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total[1m]))", "legendFormat": "{{status}}" }
      ]
    }
  ]
}
